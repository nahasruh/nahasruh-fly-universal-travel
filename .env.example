# ============================================
# Fly Universal ERP - Environment Variables
# ============================================

# Database Configuration (MySQL)
DATABASE_URL=mysql://root:password@localhost:3306/fly_universal

# Session / Auth Secrets
SESSION_SECRET=your_super_secret_session_key_change_this_in_production
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Manus OAuth
MANUS_OAUTH_CLIENT_ID=your_manus_client_id
MANUS_OAUTH_CLIENT_SECRET=your_manus_client_secret
MANUS_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Application Settings
NODE_ENV=development
PORT=3000
VITE_APP_URL=http://localhost:3000

# WhatsApp API
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id